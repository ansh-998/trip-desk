# Trip Desk — environment variables
#
# Copy this file to .env and fill in your values.
# Never commit .env — only .env.example belongs in the repo.
#
# Get your Supabase values at: https://supabase.com/dashboard/project/<your-project>/settings/api
# Get a Gemini API key at: https://aistudio.google.com

# Supabase — these are safe to expose to the browser (they're already public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Gemini — server-side only, never prefix with NEXT_PUBLIC_
GEMINI_API_KEY=your-gemini-api-key
